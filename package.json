{
  "name": "iem-dashboard",
  "version": "0.2.0",
  "bin": {
    "iem-dashboard": "bin/iem-dashboard.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "collect": "ts-node src/collector/index.ts",
    "ci": "npm run lint && npm run build && npm test",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\""
  },
  "devDependencies": {
    "@aws-sdk/client-api-gateway": "^3.500.0",
    "@aws-sdk/client-apigatewayv2": "^3.500.0",
    "@aws-sdk/client-appsync": "^3.500.0",
    "@aws-sdk/client-auto-scaling": "^3.500.0",
    "@aws-sdk/client-cloudfront": "^3.500.0",
    "@aws-sdk/client-cloudwatch": "^3.500.0",
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/client-ec2": "^3.500.0",
    "@aws-sdk/client-ecs": "^3.500.0",
    "@aws-sdk/client-efs": "^3.500.0",
    "@aws-sdk/client-elastic-load-balancing": "^3.500.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.500.0",
    "@aws-sdk/client-lambda": "^3.500.0",
    "@aws-sdk/client-medialive": "^3.500.0",
    "@aws-sdk/client-mediapackage": "^3.500.0",
    "@aws-sdk/client-rds": "^3.500.0",
    "@aws-sdk/client-resource-groups-tagging-api": "^3.500.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/client-sns": "^3.500.0",
    "@aws-sdk/client-sqs": "^3.500.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "aws-cdk": "^2.170.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "jest": "^29.0.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "cdk-nag": "^2.27.166",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21",
    "zod": "^3.22.0"
